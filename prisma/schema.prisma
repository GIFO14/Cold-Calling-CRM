generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  AGENT
}

enum CustomFieldType {
  TEXT
  NUMBER
  DATE
  BOOLEAN
  URL
}

enum ImportStatus {
  DRAFT
  PROCESSING
  COMPLETED
  FAILED
}

enum LeadActivityType {
  IMPORT_CREATED
  IMPORT_UPDATED
  NOTE
  CALL_STARTED
  CALL_ENDED
  CALL_FAILED
  STAGE_CHANGED
  FIELD_UPDATED
  FOLLOW_UP_SET
}

enum CallStatus {
  STARTED
  RINGING
  ANSWERED
  COMPLETED
  FAILED
  MISSED
  CANCELED
}

enum CallOutcome {
  NO_ANSWER
  HUNG_UP_BEFORE_ANSWER
  BUSY
  WRONG_NUMBER
  INTERESTED
  CALL_BACK
  NOT_INTERESTED
  MEETING_BOOKED
  DO_NOT_CALL
  OTHER
}

enum CallScriptSessionStatus {
  ACTIVE
  COMPLETED
  CALL_ENDED
}

enum CallScriptPane {
  SCRIPT
  OBJECTION
}

enum CallScriptSessionEventType {
  SESSION_STARTED
  STEP_SHOWN
  STEP_COMPLETED
  STEP_OPTION_SELECTED
  STEP_BACK
  OBJECTION_OPENED
  RESPONSE_SHOWN
  OBJECTION_OPTION_SELECTED
  RETURNED_TO_SCRIPT
  SESSION_COMPLETED
  SESSION_CLOSED
}

enum CallScriptBranchTargetType {
  STEP
  OBJECTION
  TERMINAL
}

model User {
  id                 String                  @id @default(cuid())
  name               String
  email              String                  @unique
  passwordHash       String
  role               UserRole                @default(AGENT)
  active             Boolean                 @default(true)
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  ownedLeads         Lead[]                  @relation("LeadOwner")
  activities         LeadActivity[]
  imports            ImportBatch[]
  callLogs           CallLog[]
  createdCallScripts CallScript[]            @relation("CallScriptCreator")
  callScriptSessions CallScriptSession[]
  telephonySettings  AgentTelephonySettings?
}

model AgentTelephonySettings {
  id                   String   @id @default(cuid())
  userId               String   @unique
  sipUsername          String
  sipPasswordEncrypted String
  sipDisplayName       String?
  sipExtension         String
  enabled              Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PbxSettings {
  id                 String   @id @default(cuid())
  sipWsUrl           String
  sipDomain          String
  outboundDialPrefix String?
  defaultCountryCode String?
  enabled            Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model BusinessSettings {
  id                    String   @id @default(cuid())
  defaultDealValueCents Int      @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model PipelineStage {
  id        String   @id @default(cuid())
  name      String
  position  Int
  color     String
  isDefault Boolean  @default(false)
  isWon     Boolean  @default(false)
  isLost    Boolean  @default(false)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  leads     Lead[]
}

model Lead {
  id              String         @id @default(cuid())
  firstName       String?
  lastName        String?
  fullName        String?
  company         String?
  jobTitle        String?
  phone           String?
  phoneNormalized String?
  phoneInvalid    Boolean        @default(false)
  phoneOptOut     Boolean        @default(false)
  email           String?
  emailNormalized String?
  emailInvalid    Boolean        @default(false)
  emailOptOut     Boolean        @default(false)
  website         String?
  linkedinUrl     String?
  source          String?
  ownerId         String?
  stageId         String?
  testing         Boolean        @default(false)
  dealValueOverrideCents Int?
  lastContactedAt DateTime?
  nextFollowUpAt  DateTime?
  customFields    Json           @default("{}")
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  owner           User?          @relation("LeadOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  stage           PipelineStage? @relation(fields: [stageId], references: [id], onDelete: SetNull)
  activities      LeadActivity[]
  callLogs        CallLog[]
  callScriptSessions CallScriptSession[]

  @@index([phoneNormalized])
  @@index([emailNormalized])
  @@index([stageId])
  @@index([ownerId])
}

model CustomFieldDefinition {
  id                  String          @id @default(cuid())
  key                 String          @unique
  label               String
  type                CustomFieldType @default(TEXT)
  createdFromImportId String?
  createdAt           DateTime        @default(now())
}

model ImportBatch {
  id          String           @id @default(cuid())
  filename    String
  status      ImportStatus     @default(DRAFT)
  totalRows   Int              @default(0)
  createdRows Int              @default(0)
  updatedRows Int              @default(0)
  skippedRows Int              @default(0)
  errorRows   Int              @default(0)
  mappingJson Json
  createdById String
  createdAt   DateTime         @default(now())
  completedAt DateTime?
  createdBy   User             @relation(fields: [createdById], references: [id])
  errors      ImportRowError[]
}

model ImportRowError {
  id            String      @id @default(cuid())
  importBatchId String
  rowNumber     Int
  rawRow        Json
  message       String
  createdAt     DateTime    @default(now())
  importBatch   ImportBatch @relation(fields: [importBatchId], references: [id], onDelete: Cascade)
}

model LeadActivity {
  id        String           @id @default(cuid())
  leadId    String
  userId    String?
  type      LeadActivityType
  title     String
  body      String?
  metadata  Json             @default("{}")
  createdAt DateTime         @default(now())
  lead      Lead             @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user      User?            @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([leadId])
}

model CallLog {
  id              String       @id @default(cuid())
  leadId          String
  userId          String?
  phoneDialed     String
  sipCallId       String?
  status          CallStatus   @default(STARTED)
  startedAt       DateTime     @default(now())
  answeredAt      DateTime?
  endedAt         DateTime?
  durationSeconds Int?
  outcome         CallOutcome?
  notes           String?
  lead            Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user            User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  callScriptSession CallScriptSession?

  @@index([leadId])
  @@index([userId])
}

model CallScript {
  id          String               @id @default(cuid())
  name        String
  languageCode String              @default("ca")
  isActive    Boolean              @default(true)
  createdById String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  createdBy   User?                @relation("CallScriptCreator", fields: [createdById], references: [id], onDelete: SetNull)
  steps       CallScriptStep[]
  objections  CallScriptObjection[]
  sessions    CallScriptSession[]

  @@index([isActive])
  @@unique([languageCode])
}

model CallScriptStep {
  id        String                   @id @default(cuid())
  scriptId  String
  position  Int
  title     String
  text      String
  advanceTargetType CallScriptBranchTargetType?
  advanceTargetStepId String?
  advanceTargetObjectionId String?
  advanceTerminalLabel String?
  createdAt DateTime                 @default(now())
  updatedAt DateTime                 @updatedAt
  script    CallScript               @relation(fields: [scriptId], references: [id], onDelete: Cascade)
  choices   CallScriptStepChoice[]
  advanceTargetStep CallScriptStep?  @relation("StepAdvanceTargetStep", fields: [advanceTargetStepId], references: [id], onDelete: SetNull)
  advanceTargetObjection CallScriptObjection? @relation("StepAdvanceTargetObjection", fields: [advanceTargetObjectionId], references: [id], onDelete: SetNull)
  incomingAdvanceSteps CallScriptStep[] @relation("StepAdvanceTargetStep")
  incomingStepChoices CallScriptStepChoice[] @relation("StepChoiceTargetStep")
  incomingObjectionChoices CallScriptObjectionChoice[] @relation("ObjectionChoiceTargetStep")
  events    CallScriptSessionEvent[]

  @@index([scriptId, position])
}

model CallScriptObjection {
  id                 String                   @id @default(cuid())
  scriptId           String
  position           Int
  label              String
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  script             CallScript               @relation(fields: [scriptId], references: [id], onDelete: Cascade)
  responses          CallScriptResponse[]
  choices            CallScriptObjectionChoice[]
  incomingAdvanceSteps CallScriptStep[]         @relation("StepAdvanceTargetObjection")
  incomingStepChoices CallScriptStepChoice[]  @relation("StepChoiceTargetObjection")
  incomingObjectionChoices CallScriptObjectionChoice[] @relation("ObjectionChoiceTargetObjection")
  selectedInSessions CallScriptSession[]      @relation("SelectedSessionObjection")
  events             CallScriptSessionEvent[]

  @@index([scriptId, position])
}

model CallScriptResponse {
  id                 String                   @id @default(cuid())
  objectionId        String
  position           Int
  label              String?
  text               String
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  objection          CallScriptObjection      @relation(fields: [objectionId], references: [id], onDelete: Cascade)
  selectedInSessions CallScriptSession[]      @relation("SelectedSessionResponse")
  events             CallScriptSessionEvent[]

  @@index([objectionId, position])
}

model CallScriptStepChoice {
  id                String                    @id @default(cuid())
  stepId            String
  position          Int
  label             String
  targetType        CallScriptBranchTargetType
  targetStepId      String?
  targetObjectionId String?
  terminalLabel     String?
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt
  step              CallScriptStep            @relation(fields: [stepId], references: [id], onDelete: Cascade)
  targetStep        CallScriptStep?           @relation("StepChoiceTargetStep", fields: [targetStepId], references: [id], onDelete: SetNull)
  targetObjection   CallScriptObjection?      @relation("StepChoiceTargetObjection", fields: [targetObjectionId], references: [id], onDelete: SetNull)

  @@index([stepId, position])
}

model CallScriptObjectionChoice {
  id                String                    @id @default(cuid())
  objectionId       String
  position          Int
  label             String
  targetType        CallScriptBranchTargetType
  targetStepId      String?
  targetObjectionId String?
  terminalLabel     String?
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt
  objection         CallScriptObjection       @relation(fields: [objectionId], references: [id], onDelete: Cascade)
  targetStep        CallScriptStep?           @relation("ObjectionChoiceTargetStep", fields: [targetStepId], references: [id], onDelete: SetNull)
  targetObjection   CallScriptObjection?      @relation("ObjectionChoiceTargetObjection", fields: [targetObjectionId], references: [id], onDelete: SetNull)

  @@index([objectionId, position])
}

model CallScriptSession {
  id                 String                   @id @default(cuid())
  scriptId           String
  leadId             String
  userId             String?
  callLogId          String?                  @unique
  status             CallScriptSessionStatus  @default(ACTIVE)
  pane               CallScriptPane           @default(SCRIPT)
  currentStepIndex   Int                      @default(0)
  highestStepIndex   Int                      @default(0)
  selectedObjectionId String?
  selectedResponseId String?
  startedAt          DateTime                 @default(now())
  endedAt            DateTime?
  endReason          String?
  script             CallScript               @relation(fields: [scriptId], references: [id], onDelete: Cascade)
  lead               Lead                     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user               User?                    @relation(fields: [userId], references: [id], onDelete: SetNull)
  callLog            CallLog?                 @relation(fields: [callLogId], references: [id], onDelete: SetNull)
  selectedObjection  CallScriptObjection?     @relation("SelectedSessionObjection", fields: [selectedObjectionId], references: [id], onDelete: SetNull)
  selectedResponse   CallScriptResponse?      @relation("SelectedSessionResponse", fields: [selectedResponseId], references: [id], onDelete: SetNull)
  events             CallScriptSessionEvent[]

  @@index([scriptId, startedAt])
  @@index([leadId, startedAt])
  @@index([userId, startedAt])
  @@index([status, startedAt])
}

model CallScriptSessionEvent {
  id          String                    @id @default(cuid())
  sessionId   String
  type        CallScriptSessionEventType
  stepId      String?
  stepPosition Int?
  objectionId String?
  responseId  String?
  metadata    Json                      @default("{}")
  createdAt   DateTime                  @default(now())
  session     CallScriptSession         @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  step        CallScriptStep?           @relation(fields: [stepId], references: [id], onDelete: SetNull)
  objection   CallScriptObjection?      @relation(fields: [objectionId], references: [id], onDelete: SetNull)
  response    CallScriptResponse?       @relation(fields: [responseId], references: [id], onDelete: SetNull)

  @@index([sessionId, createdAt])
  @@index([type, createdAt])
  @@index([objectionId, createdAt])
  @@index([responseId, createdAt])
}
